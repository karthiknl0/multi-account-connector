# ---- Vault (required) ------------------------------------------------------
# Option A: 32-byte key, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MAC_VAULT_KEY=

# Option B (instead of MAC_VAULT_KEY): a passphrase; a salt is generated and stored.
# MAC_VAULT_PASSPHRASE=

# Where the encrypted vault + audit log live (default: ~/.multi-account-connector)
# MAC_HOME=

# ---- Destructive-action policy (default off) -------------------------------
# Must be "true" for any destructive action to run, even with confirm:true.
MAC_ALLOW_DESTRUCTIVE=false

# ---- GitHub (OAuth App with Device Flow enabled) ---------------------------
GITHUB_CLIENT_ID=
# Only needed if you use a GitHub App with expiring user tokens:
# GITHUB_CLIENT_SECRET=
# GITHUB_SCOPE=read:user repo

# ---- Google (OAuth client, "Desktop app" type) ----------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_SCOPE=openid email https://www.googleapis.com/auth/drive.metadata.readonly
# GOOGLE_OAUTH_PORT=4380
